# agents/log_agent.py
import os
import sys
import json
from dotenv import load_dotenv
from langchain.agents import AgentExecutor
from langchain_core.tools import Tool
from langchain_openai import ChatOpenAI
from langchain_core.prompts import ChatPromptTemplate, MessagesPlaceholder
from langchain.agents.output_parsers import ReActSingleInputOutputParser
from langchain_core.runnables import RunnableLambda, RunnablePassthrough

# --- 路径配置 ---
current_dir = os.path.dirname(os.path.abspath(__file__))
project_root = os.path.dirname(current_dir)
if project_root not in sys.path:
    sys.path.insert(0, project_root)

# 加载环境变量
load_dotenv()

# --- 1. 导入工具模块 ---
LOG_TOOL_AVAILABLE = False
RAG_TOOL_AVAILABLE = False

try:
    from tools.log_tools import read_log_file
    LOG_TOOL_AVAILABLE = True
except ImportError as e:
    pass # 静默失败，后面会检查

try:
    from tools.retrieval_tools import retrieve_knowledge
    RAG_TOOL_AVAILABLE = True
except ImportError as e:
    pass

def get_security_tools():
    """动态构建工具列表"""
    tools = []
    
    if LOG_TOOL_AVAILABLE:
        tools.append(
            Tool(
                name="ReadLog",
                func=read_log_file,
                description=(
                    "读取指定的安全日志文件内容。\n"
                    "输入：相对路径 (如 'data/auth.log') 或绝对路径。\n"
                    "注意：如果用户提到 'auth.log' 且当前目录有 data 文件夹，请自动拼接为 'data/auth.log'。"
                )
            )
        )
    
    db_path = os.path.join(project_root, 'chroma_db')
    if RAG_TOOL_AVAILABLE and os.path.exists(db_path) and os.path.isdir(db_path):
        try:
            tools.append(
                Tool(
                    name="RetrieveKnowledge",
                    func=retrieve_knowledge,
                    description="检索本地安全知识库，用于查询 CVE 详情、攻击原理、防御建议。"
                )
            )
        except Exception:
            pass
        
    if not tools:
        # 如果连日志工具都没有，至少抛出一个清晰的错误，但在 Agent 运行时尽量不中断
        pass 
        
    return tools

def get_qwen_llm():
    """初始化通义千问 (Qwen) 模型"""
    api_key = os.getenv("DASHSCOPE_API_KEY") or os.getenv("OPENAI_API_KEY")
    
    if not api_key:
        raise ValueError("❌ 未找到 API Key! 请检查 .env 文件。")
    
    model_name = os.getenv("MODEL_NAME", "qwen-plus")
    base_url = os.getenv("OPENAI_API_BASE") or os.getenv("DASHSCOPE_BASE_URL") 
    if not base_url:
        base_url = "https://dashscope.aliyuncs.com/compatible-mode/v1"
    
    return ChatOpenAI(
        model=model_name,
        api_key=api_key,
        base_url=base_url,
        temperature=0.0,
        streaming=False
    )

def create_security_agent(llm, verbose=False):
    """构建静默版 ReAct Agent"""
    tools = get_security_tools()
    tool_names = [t.name for t in tools]
    tools_description = "\n".join([f"- {t.name}: {t.description}" for t in tools])
    
    # 【关键修改】System Prompt 强调“静默”和“只输出报告”
    SYSTEM_INSTRUCTION = f"""你是一个专业的 AI 安全日志分析助手。
可用工具：{tool_names}
工具详情：{tools_description}

【核心指令】：
1. **静默执行**：在内部进行思考 (Thought) 和调用工具 (Action)，**绝对不要**在最终回复中输出“Thought:”、“Action:”、“Observation:”等中间过程。
2. **直接报告**：用户的最终目的是看报告。请直接输出最终的《安全分析报告》。
3. **路径处理**：如果用户说“读取 auth.log”，而当前目录下有 data 文件夹，请自动尝试读取 "data/auth.log"。如果工具报错说找不到文件，请自动修正路径后重试。
4. **格式要求**：报告必须包含以下部分：
   - 🛑 攻击摘要
   - 🎯 受影响对象
   - ⚠️ 风险等级
   - 📊 攻击 IP 统计 (Top 5)
   - 🛡️ 防御建议

如果任务完成，直接输出报告内容，不要有任何开场白或结束语。
"""

    prompt = ChatPromptTemplate.from_messages([
        ("system", SYSTEM_INSTRUCTION),
        ("human", "{input}"),
        MessagesPlaceholder(variable_name="agent_scratchpad", optional=True),
    ])

    output_parser = ReActSingleInputOutputParser()
    
    def clean_scratchpad(inputs):
        scratchpad = inputs.get("agent_scratchpad", [])
        if isinstance(scratchpad, str):
            inputs["agent_scratchpad"] = []
        elif not isinstance(scratchpad, list):
            inputs["agent_scratchpad"] = []
        return inputs

    agent_chain = (
        RunnablePassthrough.assign(
            tool_names=lambda _: tool_names,
            tools=lambda _: tools_description
        )
        | RunnableLambda(clean_scratchpad)
        | prompt 
        | llm 
        | output_parser
    )
    
    executor = AgentExecutor(
        agent=agent_chain,
        tools=tools,
        verbose=verbose,  # 控制是否打印执行流，主程序传 False 则不打印
        handle_parsing_errors=True,
        max_iterations=15, # 增加一点次数以防路径修正重试
        return_intermediate_steps=False
    )
    
    return executor

def run_agent(query, verbose=False):
    """
    运行安全分析 Agent (静默模式)。
    """
    try:
        llm = get_qwen_llm()
    except Exception as e:
        raise RuntimeError(f"LLM 初始化失败：{e}")

    executor = create_security_agent(llm, verbose=verbose)
    
    # 执行 Agent
    result = executor.invoke({"input": query})
    
    # 提取结果
    if isinstance(result, dict):
        output = result.get("output", "")
        # 二次清洗：万一模型还是输出了 Thought，尝试用代码去除（双重保险）
        # 简单策略：如果输出包含 "Thought:"，只保留最后一个 "Final Answer:" 之后的内容（如果有的话）
        if "Thought:" in output and "Final Answer:" in output:
            parts = output.split("Final Answer:")
            if len(parts) > 1:
                return parts[-1].strip()
        return output.strip()
    return str(result).strip()
